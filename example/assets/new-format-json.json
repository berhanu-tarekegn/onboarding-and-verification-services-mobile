{
  "version_tag": "2026.03.27",
  "rules_config": {
    "submission_search": {
      "filters": [
        {
          "key": "national_id",
          "path": "national_id",
          "label": "National ID",
          "source": "form_data",
          "operators": ["eq", "contains"]
        },
        {
          "key": "phone_number",
          "path": "phone_number",
          "label": "Phone Number",
          "source": "form_data",
          "operators": ["eq", "contains"]
        },
        {
          "key": "name_match_score",
          "path": "steps.name_match.result_snapshot.score",
          "label": "Name Match Score",
          "source": "verification",
          "operators": ["gte", "lte"]
        }
      ]
    },
    "verification_flow": {
      "steps": [
        {
          "key": "phone_otp",
          "name": "Customer Phone OTP",
          "type": "challenge_response",
          "input": {
            "phone_number": "$answers.phone_number"
          },
          "adapter": "demo_phone_otp",
          "demo_code": "111111",
          "max_attempts": 3
        },
        {
          "key": "fayda_lookup",
          "name": "Fayda OTP and Identity Pull",
          "type": "challenge_response",
          "input": {
            "national_id": "$answers.national_id"
          },
          "adapter": "demo_fayda_otp",
          "depends_on": ["phone_otp"],
          "max_attempts": 3
        },
        {
          "key": "name_match",
          "name": "Applicant Name Match",
          "type": "comparison",
          "pairs": [
            {
              "left": "$answers.first_name",
              "label": "First Name",
              "right": "$steps.fayda_lookup.result.attributes.first_name"
            },
            {
              "left": "$answers.last_name",
              "label": "Last Name",
              "right": "$steps.fayda_lookup.result.attributes.last_name"
            }
          ],
          "adapter": "demo_fuzzy_match",
          "depends_on": ["fayda_lookup"],
          "pass_score_gte": 0.95,
          "review_score_gte": 0.8
        }
      ],
      "decision": {
        "rules": [
          {
            "all": [
              {
                "fact": "steps.phone_otp.outcome",
                "equals": "pass"
              },
              {
                "fact": "steps.fayda_lookup.outcome",
                "equals": "pass"
              },
              {
                "gte": 0.95,
                "fact": "steps.name_match.result.score"
              }
            ],
            "decision": "approved",
            "kyc_level": "level_2",
            "reason_codes": [
              "phone_verified",
              "fayda_verified",
              "name_match_passed"
            ]
          },
          {
            "all": [
              {
                "fact": "steps.phone_otp.outcome",
                "equals": "pass"
              },
              {
                "fact": "steps.fayda_lookup.outcome",
                "equals": "pass"
              },
              {
                "gte": 0.8,
                "fact": "steps.name_match.result.score"
              }
            ],
            "decision": "manual_review",
            "kyc_level": "level_1",
            "reason_codes": ["borderline_name_match"]
          }
        ],
        "fallback": {
          "decision": "rejected",
          "kyc_level": "level_0",
          "reason_codes": ["verification_failed"]
        }
      },
      "flow_key": "default",
