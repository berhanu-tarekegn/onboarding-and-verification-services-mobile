# API base (no trailing slash). Example: ngrok or production host.
BASE_URL=https://api.example.com

# When true: loads assets/mock/kyb_template.json; submit is simulated.
# When false: GET template definition and POST submission use BASE_URL.
USE_MOCK_API=true

# Sent on every request as X-Tenant-ID (required for live API).
TENANT_ID=

# Path: GET /api/v1/templates/{TEMPLATE_ID}/definitions/{DEFINITION_ID}
TEMPLATE_ID=
DEFINITION_ID=

# POST /api/v1/submissions — included as submitter_id (defaults to demo_submitter if unset).
SUBMITTER_ID=
